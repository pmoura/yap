[build-system]
requires = ["setuptools >= 77.0.3"]
build-backend = "setuptools.build_meta"

[project]
name = "yap4py"
dynamic = ["version"]

dependencies = []
requires-python = ">= 3.8"

authors = [
  {name = "Vitor Santos Costa", email = "vscode@fc.up.pt"},
]
maintainers = [
  {name = "Vitor Santos Costa", email = "vscode@fc.up.pt"},
]
description = "Call YAP from Python!"
readme = "README.md"
license = "MIT AND (Apache-2.0 OR BSD-2-Clause)"

keywords = ["prolog", "yap"]



classifiers = [
  # How mature is this project? Common values are
  #   3 - Alpha
  #   4 - Beta
  #   5 - Production/Stable
  "Development Status :: 4 - Beta",

  # Indicate who your project is intended for
  "Intended Audience :: Developers",
  "Topic :: Software Development :: Programming Languahes Tools",

  # Specify the Python versions you support here.
  "Programming Language :: YAP :: 8",
]

[project.scripts]
yapi = "yap4py:yapi"
